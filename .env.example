# =============================================================================
# Django
# =============================================================================
DJANGO_SECRET_KEY=change-me-use-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Production (Render): DEBUG=False, ALLOWED_HOSTS=your-api.onrender.com

# =============================================================================
# PostgreSQL — use ONE block (local OR Render; not both)
# =============================================================================
DB_NAME=SynDb
DB_USER=postgres
DB_PASSWORD=your-local-db-password
DB_HOST=localhost
DB_PORT=5432

# Render Postgres example (copy from Dashboard → Postgres → Connections):
# DB_NAME=syndb_xxxxx
# DB_USER=syndb_xxxxx_user
# DB_PASSWORD=...
# DB_HOST=dpg-xxxxx-a.oregon-postgres.render.com
# DB_PORT=5432
# From your PC to Render Postgres (external host) usually needs:
# DB_SSLMODE=require

# =============================================================================
# CORS — only when DEBUG=False (e.g. Vercel → Render API)
# =============================================================================
# CORS_ORIGIN=https://your-app.vercel.app

# =============================================================================
# OpenRouter (chat)
# =============================================================================
OPENROUTER_API_KEY=
OPENROUTER_Model_1=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_Model_2=
OPENROUTER_Model_3=
# Alternate spelling also supported in code:
# OPENROUTER_MODEL_1=

# Optional (OpenRouter headers)
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=

# =============================================================================
# Optional — DB verify timeouts (seconds / ms)
# =============================================================================
# DB_VERIFY_TIMEOUT=5
# DB_VERIFY_TIMEOUT_MS=5000
