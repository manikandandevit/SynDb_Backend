# Django
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=Multi-tenant-db
DB_USER=postgres
DB_PASSWORD=root
DB_HOST=localhost
DB_PORT=5432

# Credentials verify (DB connect check). Set in env only; do not hardcode.
DB_VERIFY_TIMEOUT=5
DB_VERIFY_TIMEOUT_MS=5000
DB_VERIFY_MYSQL_HOST=localhost
DB_VERIFY_MYSQL_PORT=3306
DB_VERIFY_MYSQL_USER=root
